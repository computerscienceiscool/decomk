{
  "name": "decomk (example; set DECOMK_CONF_URI)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "containerEnv": {
    "DECOMK_HOME": "/var/decomk",
    "DECOMK_LOG_DIR": "/var/log/decomk",
    "DECOMK_TOOL_URI": "go:github.com/stevegt/decomk/cmd/decomk@stable",
    "DECOMK_CONF_URI": "",
    "DECOMK_RUN_ARGS": "all"
  },
  "remoteUser": "dev",
  "postCreateCommand": "bash .devcontainer/postCreateCommand.sh"
}
